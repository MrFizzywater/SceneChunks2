{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A screenwriting project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "collaborators": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "ownerId", "createdAt", "updatedAt"]
    },
    "Scene": {
      "title": "Scene",
      "description": "A scene within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "scriptBlocks": { "type": "array", "items": { "type": "object" } },
        "order": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "revised", "final"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "title", "order", "status", "createdAt", "updatedAt"]
    },
    "Character": {
      "title": "Character",
      "description": "A character in the script",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "description": { "type": "string" },
        "traits": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "name", "createdAt", "updatedAt"]
    },
    "ProductionElement": {
      "title": "ProductionElement",
      "description": "A production element like crew, prop, location, etc.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "category": { "type": "string", "enum": ["crew", "prop", "location", "music", "sfx", "vfx"] },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "sceneId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "category", "name", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Screenwriting projects"
    },
    "/projects/{projectId}/scenes/{sceneId}": {
      "schema": { "$ref": "#/entities/Scene" },
      "description": "Scenes within a project"
    }
  }
}
